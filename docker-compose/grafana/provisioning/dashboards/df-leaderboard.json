{
  "title": "Deploy Race — Leaderboard",
  "uid": "dora-df-leaderboard",
  "description": "Weekly / monthly deploy leaderboard. Podium, momentum movers, and the full ranked table — who climbed, who fell, who's new.",
  "tags": ["dora", "deployment-frequency", "leaderboard", "fun"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1,
  "graphTooltip": 0,

  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(argocd_app_info, dest_namespace)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      },
      {
        "name": "period",
        "label": "Race Period",
        "type": "custom",
        "query": "7d,30d",
        "current": { "text": "7d", "value": "7d" },
        "options": [
          { "text": "7d",  "value": "7d",  "selected": true  },
          { "text": "30d", "value": "30d", "selected": false }
        ],
        "includeAll": false,
        "multi": false
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "🏁 Top 3 This Period",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 2,
      "type": "stat",
      "title": "🚀  #1  Pole Position",
      "description": "Top deployed service this period by raw deploy count.",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#E53935" },
          "noValue": "—"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": { "titleSize": 18, "valueSize": 52 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(1, increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period]))",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "⚡  #2  Fast Lane",
      "description": "Second-highest deployer this period.",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#1E88E5" },
          "noValue": "—"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": { "titleSize": 18, "valueSize": 52 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(2, increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period])) unless topk(1, increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period]))",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "🔥  #3  Hot Pursuit",
      "description": "Third-highest deployer this period.",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#FB8C00" },
          "noValue": "—"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": { "titleSize": 18, "valueSize": 52 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(3, increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period])) unless topk(2, increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period]))",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    },

    {
      "id": 5,
      "type": "row",
      "title": "📈 Momentum — This Period vs Last Period",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 6,
      "type": "bargauge",
      "title": "⬆  Biggest Climbers (deploy count gained vs last period)",
      "description": "Services with the largest increase in raw deploy count compared to the previous period of the same length.",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#66BB6A" },
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "minVizHeight": 10,
        "text": { "titleSize": 13, "valueSize": 18 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, (\n  increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period])\n  -\n  increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period] offset $period)\n) > 0)",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    },

    {
      "id": 7,
      "type": "bargauge",
      "title": "⬇  Biggest Fallers (deploy count dropped vs last period)",
      "description": "Services with the largest drop in raw deploy count. Bar length = how many deploys they lost vs last period.",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#EF5350" },
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "minVizHeight": 10,
        "text": { "titleSize": 13, "valueSize": 18 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "-(bottomk(10, (\n  increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period])\n  -\n  increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period] offset $period)\n) < 0))",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    },

    {
      "id": 8,
      "type": "row",
      "title": "📊 Full Leaderboard",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 9,
      "type": "table",
      "title": "Ranked Leaderboard — This Period vs Last Period",
      "description": "Sorted by deploy count this period (row 1 = rank #1). Change = this period minus last period. Green = improved, red = fell, gray = same.",
      "gridPos": { "x": 0, "y": 21, "w": 17, "h": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Change" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#EF5350", "value": null },
                    { "color": "text",    "value": 0    },
                    { "color": "#66BB6A", "value": 1    }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "This Period" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "transparent", "value": 0   }
                  ]
                }
              },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Service" },
            "properties": [
              { "id": "custom.width", "value": 220 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Namespace" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": true, "reducer": ["sum"], "fields": ["This Period", "Last Period"] },
        "sortBy": [{ "displayName": "This Period", "desc": true }],
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "This Period",
              "Value #B": "Last Period",
              "name": "Service",
              "dest_namespace": "Namespace"
            },
            "excludeByName": {
              "Time": true,
              "namespace": true,
              "__name__": true,
              "phase": true,
              "job": true,
              "instance": true
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Change",
            "mode": "binaryOperation",
            "binary": {
              "left": "This Period",
              "right": "Last Period",
              "operator": "-"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "displayName": "This Period", "desc": true }]
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "refId": "A",
          "expr": "increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period])",
          "legendFormat": "{{name}}",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "refId": "B",
          "expr": "increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period] offset $period)",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    },

    {
      "id": 10,
      "type": "stat",
      "title": "🆕  New Entries",
      "description": "Services that deployed this period but had zero (or no) deploys the prior period.",
      "gridPos": { "x": 17, "y": 21, "w": 7, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#29B6F6" },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "titleSize": 14, "valueSize": 40 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(\n  (increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period]) > 0)\n  unless\n  (increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period] offset $period) > 0)\n) or vector(0)",
          "legendFormat": "services",
          "instant": true
        }
      ]
    },

    {
      "id": 11,
      "type": "stat",
      "title": "⬆  Improved",
      "description": "Services that deployed more this period than last.",
      "gridPos": { "x": 17, "y": 26, "w": 4, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#66BB6A" },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "titleSize": 13, "valueSize": 36 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(\n  (\n    increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period])\n    -\n    increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period] offset $period)\n  ) > 0\n) or vector(0)",
          "legendFormat": "services",
          "instant": true
        }
      ]
    },

    {
      "id": 12,
      "type": "stat",
      "title": "⬇  Declined",
      "description": "Services that deployed less this period than last.",
      "gridPos": { "x": 21, "y": 26, "w": 3, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#EF5350" },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "titleSize": 13, "valueSize": 36 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(\n  (\n    increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period])\n    -\n    increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period] offset $period)\n  ) < 0\n) or vector(0)",
          "legendFormat": "services",
          "instant": true
        }
      ]
    },

    {
      "id": 13,
      "type": "stat",
      "title": "Total Deploys",
      "description": "All successful deploys across selected namespaces this period.",
      "gridPos": { "x": 17, "y": 32, "w": 7, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "#78909C" },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "titleSize": 14, "valueSize": 40 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(argocd_app_sync_total{phase=\"Succeeded\", dest_namespace=~\"$namespace\"}[$period]))",
          "legendFormat": "deploys",
          "instant": true
        }
      ]
    },

    {
      "id": 14,
      "type": "row",
      "title": "🏁 The Race — Deploy Rate Over Time (Top 10)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 15,
      "type": "timeseries",
      "title": "Deploy Velocity — Top 10 Services (deploys/hr, rolling 1h)",
      "description": "Rolling hourly deploy rate for the top 10 services. Lines that stay high are consistently fast. Spikes = deployment bursts. Who's racing ahead?",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max", "sum"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, dora:deployment_frequency:daily{dest_namespace=~\"$namespace\"})",
          "legendFormat": "{{name}}"
        }
      ]
    }

  ]
}
